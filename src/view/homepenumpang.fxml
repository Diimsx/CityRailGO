<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.HomePenumpangController"
            prefWidth="1280" prefHeight="720"
            stylesheets="@HomePenumpang.css"
            styleClass="root-bg">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox prefWidth="240" prefHeight="720" styleClass="sidebar">
            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <FontIcon iconLiteral="fas-train" iconSize="26" styleClass="brand-icon"/>
                <Label text="CityRailGO" styleClass="brand-text"/>
                <Label text="Portal Penumpang" styleClass="brand-subtext"/>
            </VBox>

            <VBox styleClass="nav-list">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item-active" onMouseClicked="#handleNavBeranda">
                    <FontIcon iconLiteral="fas-home" styleClass="nav-icon-active"/>
                    <Label text="Beranda" styleClass="nav-label-active"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavTiketSaya">
                    <FontIcon iconLiteral="fas-ticket-alt" styleClass="nav-icon"/>
                    <Label text="Tiket Saya" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavProfil">
                    <FontIcon iconLiteral="fas-user-circle" styleClass="nav-icon"/>
                    <Label text="Profil" styleClass="nav-label"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="logout-item" onMouseClicked="#handleLogout">
                <FontIcon iconLiteral="fas-sign-out-alt" styleClass="logout-icon"/>
                <Label text="Logout" styleClass="logout-label"/>
            </HBox>
        </VBox>
    </left>

    <!-- ===================== KONTEN UTAMA ===================== -->
    <center>
        <VBox>
            <!-- Topbar -->
            <HBox alignment="CENTER_LEFT" styleClass="topbar">
                <VBox>
                    <Label text="Beranda" styleClass="page-title"/>
                    <Label text="Selamat datang, temukan jadwal kereta Anda" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="10" styleClass="user-badge">
                    <FontIcon fx:id="topbarIcon" iconLiteral="fas-user-circle" styleClass="nav-icon"/>
                    <ImageView fx:id="topbarAvatar" visible="false" managed="false"/>
                    <Label fx:id="lblNama" text="Penumpang" styleClass="user-name"/>
                </HBox>
            </HBox>

            <!-- Scrollable Content -->
            <ScrollPane styleClass="content-scroll" VBox.vgrow="ALWAYS"
                        fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                <VBox spacing="24">
                    <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                    <!-- Hero Banner -->
                    <HBox styleClass="hero-card" spacing="0" alignment="CENTER_LEFT">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Perjalanan Anda," styleClass="hero-title"/>
                            <Label text="Mulai Di Sini." styleClass="hero-title"/>
                            <Label text="Cari dan pesan tiket kereta api dengan mudah dan cepat" styleClass="hero-subtitle"/>
                        </VBox>
                        <HBox spacing="32" alignment="CENTER_RIGHT">
                            <VBox alignment="CENTER" spacing="4">
                                <Label fx:id="lblStatJadwal" text="—" styleClass="hero-stat-value"/>
                                <Label text="Jadwal Aktif" styleClass="hero-stat-label"/>
                            </VBox>
                            <VBox styleClass="hero-divider"/>
                            <VBox alignment="CENTER" spacing="4">
                                <Label fx:id="lblStatRute" text="—" styleClass="hero-stat-value"/>
                                <Label text="Rute Tersedia" styleClass="hero-stat-label"/>
                            </VBox>
                            <VBox styleClass="hero-divider"/>
                            <VBox alignment="CENTER" spacing="4">
                                <Label fx:id="lblStatTiketSaya" text="—" styleClass="hero-stat-value"/>
                                <Label text="Tiket Saya" styleClass="hero-stat-label"/>
                            </VBox>
                        </HBox>
                    </HBox>

                    <!-- Form Pencarian + Promo (2 kolom) -->
                    <HBox spacing="20" alignment="TOP_LEFT">

                        <!-- KIRI: Form Pencarian -->
                        <VBox styleClass="search-card" spacing="20" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontIcon iconLiteral="fas-search" styleClass="info-icon-blue"/>
                                <VBox>
                                    <Label text="Cari Jadwal Kereta" styleClass="search-card-title"/>
                                    <Label text="Isi form berikut untuk menemukan jadwal yang sesuai" styleClass="search-card-subtitle"/>
                                </VBox>
                            </HBox>

                            <!-- Asal + swap + Tujuan -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <FontIcon iconLiteral="fas-map-marker-alt" styleClass="info-icon-blue"/>
                                        <Label text="Stasiun Asal" styleClass="form-label"/>
                                    </HBox>
                                    <ComboBox fx:id="cbAsal" promptText="Pilih stasiun keberangkatan..."
                                              styleClass="form-field" maxWidth="Infinity"/>
                                </VBox>
                                <VBox alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                                    <Button styleClass="swap-btn" onAction="#handleSwapStasiun">
                                        <graphic><FontIcon iconLiteral="fas-exchange-alt" styleClass="swap-icon"/></graphic>
                                    </Button>
                                </VBox>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <FontIcon iconLiteral="fas-flag-checkered" styleClass="info-icon-green"/>
                                        <Label text="Stasiun Tujuan" styleClass="form-label"/>
                                    </HBox>
                                    <ComboBox fx:id="cbTujuan" promptText="Pilih stasiun tujuan..."
                                              styleClass="form-field" maxWidth="Infinity"/>
                                </VBox>
                            </HBox>

                            <!-- Tanggal + Jumlah -->
                            <HBox spacing="12">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <FontIcon iconLiteral="fas-calendar-alt" styleClass="info-icon-orange"/>
                                        <Label text="Tanggal Berangkat" styleClass="form-label"/>
                                    </HBox>
                                    <DatePicker fx:id="dpTanggal" promptText="Pilih tanggal..."
                                                styleClass="form-field" maxWidth="Infinity"/>
                                </VBox>
                                <VBox spacing="6" prefWidth="200">
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <FontIcon iconLiteral="fas-users" styleClass="info-icon-blue"/>
                                        <Label text="Jumlah Penumpang" styleClass="form-label"/>
                                    </HBox>
                                    <Spinner fx:id="spJumlah" min="1" max="8" initialValue="1"
                                             styleClass="form-field" prefHeight="42"/>
                                </VBox>
                            </HBox>

                            <Label fx:id="lblError" text="" styleClass="error-label"
                                   visible="false" managed="false" wrapText="true"/>

                            <Button styleClass="btn-search" maxWidth="Infinity" onAction="#handleCariJadwal">
                                <graphic>
                                    <HBox alignment="CENTER" spacing="10">
                                        <FontIcon iconLiteral="fas-search" styleClass="btn-search-icon"/>
                                        <Label text="Cari Jadwal Kereta"
                                               style="-fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14px;"/>
                                    </HBox>
                                </graphic>
                            </Button>
                        </VBox>

                        <!-- KANAN: Promo -->
                        <VBox styleClass="promo-card" spacing="16" prefWidth="320" minWidth="290">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontIcon iconLiteral="fas-tags" styleClass="info-icon-orange"/>
                                <VBox>
                                    <Label text="Promo Tersedia" styleClass="search-card-title"/>
                                    <Label text="Gunakan kode saat pembayaran" styleClass="search-card-subtitle"/>
                                </VBox>
                            </HBox>
                            <!-- Promo cards — di-generate controller -->
                            <VBox fx:id="vboxPromo" spacing="12"/>
                            <Label fx:id="lblNoPromo" text="Belum ada promo aktif saat ini."
                                   styleClass="no-promo-label" visible="false" managed="false" wrapText="true"/>
                        </VBox>
                    </HBox>

                    <!-- Info Cards -->
                    <HBox spacing="20">
                        <VBox styleClass="info-card" spacing="14" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="14">
                                <StackPane styleClass="info-card-icon-box, info-card-icon-blue">
                                    <FontIcon iconLiteral="fas-shield-alt" styleClass="info-card-icon, info-icon-blue"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Terjamin Aman" styleClass="info-card-label"/>
                                    <Label text="Sistem Terpercaya" styleClass="info-card-value" style="-fx-font-size:16px;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="info-card" spacing="14" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="14">
                                <StackPane styleClass="info-card-icon-box, info-card-icon-green">
                                    <FontIcon iconLiteral="fas-bolt" styleClass="info-card-icon, info-icon-green"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Pesan Cepat" styleClass="info-card-label"/>
                                    <Label text="Booking Instan" styleClass="info-card-value" style="-fx-font-size:16px;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox styleClass="info-card" spacing="14" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="14">
                                <StackPane styleClass="info-card-icon-box, info-card-icon-orange">
                                    <FontIcon iconLiteral="fas-print" styleClass="info-card-icon, info-icon-orange"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="E-Tiket Digital" styleClass="info-card-label"/>
                                    <Label text="Cetak Langsung" styleClass="info-card-value" style="-fx-font-size:16px;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="720" prefWidth="1280" styleClass="root-bg" stylesheets="@HomeAdmin.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.HomeAdminController">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox prefHeight="720" prefWidth="240" styleClass="sidebar">

            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <FontIcon iconLiteral="fas-train" iconSize="26" styleClass="brand-icon" />
                <Label styleClass="brand-text" text="CityRailGO" />
                <Label styleClass="brand-subtext" text="Admin Panel" />
            </VBox>

            <VBox styleClass="nav-list">
                <HBox alignment="CENTER_LEFT" onMouseClicked="#handleNavDashboard" spacing="14" styleClass="nav-item-active">
                    <FontIcon iconLiteral="fas-th-large" styleClass="nav-icon-active" />
                    <Label styleClass="nav-label-active" text="Dashboard" />
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#handleNavKereta" spacing="14" styleClass="nav-item">
                    <FontIcon iconLiteral="fas-train" styleClass="nav-icon" />
                    <Label styleClass="nav-label" text="Kelola Kereta" />
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#handleNavRute" spacing="14" styleClass="nav-item">
                    <FontIcon iconLiteral="fas-route" styleClass="nav-icon" />
                    <Label styleClass="nav-label" text="Kelola Rute" />
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#handleNavJadwal" spacing="14" styleClass="nav-item">
                    <FontIcon iconLiteral="fas-calendar-alt" styleClass="nav-icon" />
                    <Label styleClass="nav-label" text="Kelola Jadwal" />
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#handleNavPromo" spacing="14" styleClass="nav-item">
                    <FontIcon iconLiteral="fas-percent" styleClass="nav-icon" />
                    <Label styleClass="nav-label" text="Kelola Promo" />
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#handleNavValidasi" spacing="14" styleClass="nav-item">
               <children>
                       <FontIcon iconLiteral="fas-chart-bar" styleClass="nav-icon" />
                       <Label styleClass="nav-label" text="Laporan Penjualan" />
               </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" onMouseClicked="#handleNavLaporan" spacing="14" styleClass="nav-item" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" onMouseClicked="#handleLogout" spacing="14" styleClass="logout-item">
                <FontIcon iconLiteral="fas-sign-out-alt" styleClass="logout-icon" />
                <Label styleClass="logout-label" text="Logout" />
            </HBox>

        </VBox>
    </left>

    <!-- ===================== KONTEN UTAMA ===================== -->
    <center>
        <VBox styleClass="content-area">

            <HBox alignment="CENTER_LEFT" styleClass="topbar">
                <VBox>
                    <Label styleClass="page-title" text="Dashboard" />
                    <Label styleClass="page-subtitle" text="Ringkasan aktivitas CityRailGO" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblAdminName" styleClass="admin-name" text="Halo, Admin" />
            </HBox>

            <HBox spacing="20" styleClass="stat-row">

                <VBox alignment="CENTER_LEFT" spacing="8" styleClass="stat-card">
                    <FontIcon iconLiteral="fas-ticket-alt" styleClass="stat-icon icon-blue" />
                    <Label fx:id="lblTotalTiket" styleClass="stat-value" text="0" />
                    <Label styleClass="stat-label" text="Total Tiket Terjual" />
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="8" styleClass="stat-card">
                    <FontIcon iconLiteral="fas-money-bill-wave" styleClass="stat-icon icon-green" />
                    <Label fx:id="lblTotalPendapatan" styleClass="stat-value" text="Rp 0" />
                    <Label styleClass="stat-label" text="Total Pendapatan" />
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="8" styleClass="stat-card">
                    <FontIcon iconLiteral="fas-train" styleClass="stat-icon icon-purple" />
                    <Label fx:id="lblTotalKereta" styleClass="stat-value" text="0" />
                    <Label styleClass="stat-label" text="Total Kereta" />
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="8" styleClass="stat-card">
                    <FontIcon iconLiteral="fas-users" styleClass="stat-icon icon-orange" />
                    <Label fx:id="lblTotalPenumpang" styleClass="stat-value" text="0" />
                    <Label styleClass="stat-label" text="Total Penumpang" />
                </VBox>

            </HBox>

            <VBox spacing="14" styleClass="table-card">
                <Label styleClass="card-title" text="Tiket Terbaru" />
                <TableView fx:id="tblTiketTerbaru" styleClass="ticket-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colKodeTiket" prefWidth="140" text="Kode Tiket" />
                        <TableColumn fx:id="colPenumpang" prefWidth="180" text="Penumpang" />
                        <TableColumn fx:id="colKereta" prefWidth="150" text="Kereta" />
                        <TableColumn fx:id="colRute" prefWidth="230" text="Rute" />
                        <TableColumn fx:id="colStatus" prefWidth="100" text="Status" />
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>

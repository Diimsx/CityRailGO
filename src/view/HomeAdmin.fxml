<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.HomeAdminController"
    stylesheets="@../css/HomeAdmin.css"
    prefWidth="1280"
    prefHeight="760">

    <!-- ═══════════════════════════════════
         SIDEBAR (LEFT)
    ═══════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar">

            <!-- Logo -->
            <HBox styleClass="sidebar-logo" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="fas-train" iconSize="22" styleClass="logo-icon"/>
                <Label text="CityRailGO" styleClass="logo-text"/>
            </HBox>

            <!-- Admin Profile Card -->
            <HBox styleClass="admin-profile" alignment="CENTER_LEFT">
                <StackPane styleClass="avatar">
                    <Label fx:id="labelAvatarInitial" text="A" styleClass="avatar-label"/>
                </StackPane>
                <VBox styleClass="admin-info">
                    <Label fx:id="labelAdminName" text="Administrator" styleClass="admin-name"/>
                    <Label text="Super Admin" styleClass="admin-role"/>
                </VBox>
            </HBox>

            <!-- Divider -->
            <Region styleClass="sidebar-divider"/>

            <!-- Navigation Section Label -->
            <Label text="MENU UTAMA" styleClass="nav-section-label"/>

            <!-- Nav Items -->
            <VBox styleClass="nav-items" VBox.vgrow="ALWAYS">

                <Button fx:id="btnDashboard" styleClass="nav-btn" maxWidth="Infinity"
                        mnemonicParsing="false" onAction="#handleDashboard">
                    <graphic>
                        <HBox styleClass="nav-btn-content" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-th-large" iconSize="15" styleClass="nav-icon"/>
                            <Label text="Dashboard" styleClass="nav-label" mouseTransparent="true"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="btnKereta" styleClass="nav-btn" maxWidth="Infinity"
                        mnemonicParsing="false" onAction="#handleKereta">
                    <graphic>
                        <HBox styleClass="nav-btn-content" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-train" iconSize="15" styleClass="nav-icon"/>
                            <Label text="Manajemen Kereta" styleClass="nav-label" mouseTransparent="true"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="btnRute" styleClass="nav-btn" maxWidth="Infinity"
                        mnemonicParsing="false" onAction="#handleRute">
                    <graphic>
                        <HBox styleClass="nav-btn-content" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-route" iconSize="15" styleClass="nav-icon"/>
                            <Label text="Manajemen Rute" styleClass="nav-label" mouseTransparent="true"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="btnJadwal" styleClass="nav-btn" maxWidth="Infinity"
                        mnemonicParsing="false" onAction="#handleJadwal">
                    <graphic>
                        <HBox styleClass="nav-btn-content" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-calendar-alt" iconSize="15" styleClass="nav-icon"/>
                            <Label text="Manajemen Jadwal" styleClass="nav-label" mouseTransparent="true"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="btnPenumpang" styleClass="nav-btn" maxWidth="Infinity"
                        mnemonicParsing="false" onAction="#handlePenumpang">
                    <graphic>
                        <HBox styleClass="nav-btn-content" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-users" iconSize="15" styleClass="nav-icon"/>
                            <Label text="Data Penumpang" styleClass="nav-label" mouseTransparent="true"/>
                        </HBox>
                    </graphic>
                </Button>

                <Button fx:id="btnPemesanan" styleClass="nav-btn" maxWidth="Infinity"
                        mnemonicParsing="false" onAction="#handlePemesanan">
                    <graphic>
                        <HBox styleClass="nav-btn-content" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-ticket-alt" iconSize="15" styleClass="nav-icon"/>
                            <Label text="Data Pemesanan" styleClass="nav-label" mouseTransparent="true"/>
                        </HBox>
                    </graphic>
                </Button>

                <!-- Spacer pushes logout to bottom -->
                <Region VBox.vgrow="ALWAYS"/>

                <!-- Divider -->
                <Region styleClass="sidebar-divider"/>

                <!-- Logout -->
                <Button fx:id="btnLogout" styleClass="nav-btn nav-btn-logout" maxWidth="Infinity"
                        mnemonicParsing="false" onAction="#handleLogout">
                    <graphic>
                        <HBox styleClass="nav-btn-content" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-sign-out-alt" iconSize="15" styleClass="nav-icon"/>
                            <Label text="Keluar" styleClass="nav-label" mouseTransparent="true"/>
                        </HBox>
                    </graphic>
                </Button>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════
         MAIN CONTENT (CENTER)
    ═══════════════════════════════════ -->
    <center>
        <VBox styleClass="main-content">

            <!-- Top Header Bar -->
            <HBox styleClass="top-header" alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS" spacing="2">
                    <Label text="Dashboard" styleClass="page-title"/>
                    <Label fx:id="labelDateTime" text="Memuat tanggal..." styleClass="page-subtitle"/>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="8">
                    <Button styleClass="icon-btn" mnemonicParsing="false"
                            onAction="#handleRefresh" tooltip-text="refresh">
                        <graphic>
                            <FontIcon iconLiteral="fas-sync-alt" iconSize="14" styleClass="icon-btn-icon"/>
                        </graphic>
                    </Button>
                    <Button styleClass="icon-btn" mnemonicParsing="false">
                        <graphic>
                            <FontIcon iconLiteral="fas-bell" iconSize="14" styleClass="icon-btn-icon"/>
                        </graphic>
                    </Button>
                </HBox>
            </HBox>

            <!-- Scrollable Content Area -->
            <ScrollPane styleClass="main-scroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                <VBox styleClass="content-area" spacing="20">

                    <!-- ─── STAT CARDS ROW ─── -->
                    <GridPane styleClass="stats-grid" hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <!-- Card: Total Pemesanan -->
                        <VBox styleClass="stat-card" spacing="10" GridPane.columnIndex="0">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane styleClass="stat-icon-wrap stat-icon-blue">
                                    <FontIcon iconLiteral="fas-ticket-alt" iconSize="18" styleClass="stat-icon"/>
                                </StackPane>
                                <Label text="Total Pemesanan" styleClass="stat-label"/>
                            </HBox>
                            <Label fx:id="labelTotalPemesanan" text="—" styleClass="stat-value"/>
                            <HBox alignment="CENTER_LEFT" spacing="5">
                                <FontIcon iconLiteral="fas-arrow-up" iconSize="9" styleClass="trend-icon-up"/>
                                <Label fx:id="labelTrendPemesanan" text="+0% bulan ini" styleClass="stat-trend"/>
                            </HBox>
                        </VBox>

                        <!-- Card: Total Pendapatan -->
                        <VBox styleClass="stat-card" spacing="10" GridPane.columnIndex="1">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane styleClass="stat-icon-wrap stat-icon-green">
                                    <FontIcon iconLiteral="fas-money-bill-wave" iconSize="18" styleClass="stat-icon"/>
                                </StackPane>
                                <Label text="Total Pendapatan" styleClass="stat-label"/>
                            </HBox>
                            <Label fx:id="labelTotalPendapatan" text="—" styleClass="stat-value"/>
                            <HBox alignment="CENTER_LEFT" spacing="5">
                                <FontIcon iconLiteral="fas-arrow-up" iconSize="9" styleClass="trend-icon-up"/>
                                <Label fx:id="labelTrendPendapatan" text="+0% bulan ini" styleClass="stat-trend"/>
                            </HBox>
                        </VBox>

                        <!-- Card: Total Penumpang -->
                        <VBox styleClass="stat-card" spacing="10" GridPane.columnIndex="2">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane styleClass="stat-icon-wrap stat-icon-purple">
                                    <FontIcon iconLiteral="fas-users" iconSize="18" styleClass="stat-icon"/>
                                </StackPane>
                                <Label text="Total Penumpang" styleClass="stat-label"/>
                            </HBox>
                            <Label fx:id="labelTotalPenumpang" text="—" styleClass="stat-value"/>
                            <HBox alignment="CENTER_LEFT" spacing="5">
                                <FontIcon iconLiteral="fas-arrow-up" iconSize="9" styleClass="trend-icon-up"/>
                                <Label fx:id="labelTrendPenumpang" text="+0% bulan ini" styleClass="stat-trend"/>
                            </HBox>
                        </VBox>

                        <!-- Card: Jadwal Aktif -->
                        <VBox styleClass="stat-card" spacing="10" GridPane.columnIndex="3">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane styleClass="stat-icon-wrap stat-icon-amber">
                                    <FontIcon iconLiteral="fas-calendar-check" iconSize="18" styleClass="stat-icon"/>
                                </StackPane>
                                <Label text="Jadwal Aktif" styleClass="stat-label"/>
                            </HBox>
                            <Label fx:id="labelJadwalAktif" text="—" styleClass="stat-value"/>
                            <HBox alignment="CENTER_LEFT" spacing="5">
                                <FontIcon iconLiteral="fas-clock" iconSize="9" styleClass="trend-icon-flat"/>
                                <Label text="Hari ini" styleClass="stat-trend"/>
                            </HBox>
                        </VBox>
                    </GridPane>

                    <!-- ─── BOTTOM ROW: TABLE + SIDE PANELS ─── -->
                    <HBox spacing="16" alignment="TOP_LEFT">

                        <!-- Recent Pemesanan Table Panel -->
                        <VBox styleClass="panel-card" HBox.hgrow="ALWAYS" spacing="0">

                            <!-- Panel Header -->
                            <HBox styleClass="panel-header" alignment="CENTER_LEFT">
                                <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                                    <FontIcon iconLiteral="fas-list-alt" iconSize="14" styleClass="panel-header-icon"/>
                                    <Label text="Pemesanan Terbaru" styleClass="panel-title"/>
                                </HBox>
                                <Button styleClass="btn-text-link" text="Lihat Semua →"
                                        mnemonicParsing="false" onAction="#handlePemesanan"/>
                            </HBox>

                            <!-- Table -->
                            <TableView fx:id="tablePemesanan" styleClass="modern-table"
                                       VBox.vgrow="ALWAYS" minHeight="320">
                                <columns>
                                    <TableColumn fx:id="colKode" text="Kode Booking" prefWidth="140"/>
                                    <TableColumn fx:id="colNama" text="Penumpang" prefWidth="160"/>
                                    <TableColumn fx:id="colRute" text="Rute" prefWidth="190"/>
                                    <TableColumn fx:id="colTanggal" text="Tanggal Berangkat" prefWidth="150"/>
                                    <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                                </columns>
                                <placeholder>
                                    <VBox alignment="CENTER" spacing="10" style="-fx-padding: 48;">
                                        <FontIcon iconLiteral="fas-inbox" iconSize="36"
                                                  style="-fx-icon-color: #CBD5E1;"/>
                                        <Label text="Belum ada data pemesanan"
                                               style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
                                    </VBox>
                                </placeholder>
                            </TableView>
                        </VBox>

                        <!-- Right Side Panels -->
                        <VBox spacing="16" prefWidth="256" minWidth="240">

                            <!-- Quick Actions Panel -->
                            <VBox styleClass="panel-card" spacing="12">
                                <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8">
                                    <FontIcon iconLiteral="fas-bolt" iconSize="13" styleClass="panel-header-icon"/>
                                    <Label text="Aksi Cepat" styleClass="panel-title"/>
                                </HBox>
                                <VBox spacing="8">
                                    <Button styleClass="quick-btn" maxWidth="Infinity"
                                            mnemonicParsing="false" onAction="#handleKereta">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <FontIcon iconLiteral="fas-plus-circle" iconSize="13"
                                                          styleClass="quick-btn-icon"/>
                                                <Label text="Tambah Kereta" mouseTransparent="true"
                                                       styleClass="quick-btn-label"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <Button styleClass="quick-btn" maxWidth="Infinity"
                                            mnemonicParsing="false" onAction="#handleRute">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <FontIcon iconLiteral="fas-plus-circle" iconSize="13"
                                                          styleClass="quick-btn-icon"/>
                                                <Label text="Tambah Rute" mouseTransparent="true"
                                                       styleClass="quick-btn-label"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                    <Button styleClass="quick-btn" maxWidth="Infinity"
                                            mnemonicParsing="false" onAction="#handleJadwal">
                                        <graphic>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <FontIcon iconLiteral="fas-plus-circle" iconSize="13"
                                                          styleClass="quick-btn-icon"/>
                                                <Label text="Buat Jadwal" mouseTransparent="true"
                                                       styleClass="quick-btn-label"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                </VBox>
                            </VBox>

                            <!-- System Status Panel -->
                            <VBox styleClass="panel-card" spacing="14">
                                <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8">
                                    <FontIcon iconLiteral="fas-server" iconSize="13" styleClass="panel-header-icon"/>
                                    <Label text="Status Sistem" styleClass="panel-title"/>
                                </HBox>
                                <VBox spacing="12">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <StackPane styleClass="dot dot-green"/>
                                        <Label text="Database" styleClass="status-item-label" HBox.hgrow="ALWAYS"/>
                                        <Label text="Online" styleClass="status-item-value status-ok"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <StackPane styleClass="dot dot-green"/>
                                        <Label text="Aplikasi" styleClass="status-item-label" HBox.hgrow="ALWAYS"/>
                                        <Label text="Aktif" styleClass="status-item-value status-ok"/>
                                    </HBox>
                                    <Region styleClass="status-divider"/>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <StackPane styleClass="dot dot-blue"/>
                                        <Label text="Versi" styleClass="status-item-label" HBox.hgrow="ALWAYS"/>
                                        <Label text="v1.0.0" styleClass="status-item-value status-info"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <StackPane styleClass="dot dot-blue"/>
                                        <Label text="Mode" styleClass="status-item-label" HBox.hgrow="ALWAYS"/>
                                        <Label text="Admin" styleClass="status-item-value status-info"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                        </VBox>
                    </HBox>

                    <!-- Bottom padding -->
                    <Region minHeight="8"/>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>

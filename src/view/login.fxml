<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="720" prefWidth="1280" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">

    <!-- Panel kiri: branding -->
    <VBox alignment="CENTER" prefHeight="720" prefWidth="640" spacing="20" style="-fx-background-color: #0d1b3e;">
        <Label style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white;" text="CityRailGO" />
        <Label style="-fx-font-size: 15px; -fx-text-fill: #9fb4e0;" text="Pesan tiket kereta lebih cepat, lebih mudah" />
    </VBox>

    <!-- Panel kanan: form login -->
    <VBox alignment="CENTER" prefHeight="720" prefWidth="640" spacing="16" style="-fx-background-color: #f0f4ff;">

        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a3c8f;" text="Selamat datang" />

        <Label style="-fx-font-size: 13px; -fx-text-fill: #666666;" text="Login untuk melanjutkan" />

        <VBox maxWidth="320" spacing="6">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold;" text="Username" />
            <TextField fx:id="tfUsername" prefWidth="320" promptText="Masukkan username" style="-fx-background-radius: 8; -fx-border-radius: 8;                               -fx-border-color: #c0c8e8; -fx-padding: 8;" />
        </VBox>

        <VBox maxWidth="320" spacing="6">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold;" text="Password" />
            <PasswordField fx:id="pfPassword" prefWidth="320" promptText="Masukkan password" style="-fx-background-radius: 8; -fx-border-radius: 8;                                   -fx-border-color: #c0c8e8; -fx-padding: 8;" />
        </VBox>

        <Label fx:id="lblError" maxWidth="320" style="-fx-text-fill: #d32f2f; -fx-font-size: 12px;" text="" visible="false" wrapText="true" />

        <Button fx:id="btnLogin" onAction="#handleLogin" prefHeight="42" prefWidth="320" style="-fx-background-color: #1a3c8f; -fx-text-fill: white;                        -fx-font-size: 14px; -fx-font-weight: bold;                        -fx-background-radius: 8; -fx-cursor: hand;" text="Login" />

        <HBox alignment="CENTER" spacing="4">
            <Label style="-fx-font-size: 12px;" text="Belum punya akun?" />
            <Hyperlink onAction="#handleGoToRegister" style="-fx-font-size: 12px; -fx-text-fill: #1a3c8f;" text="Daftar di sini" />
        </HBox>
    </VBox>
</HBox>

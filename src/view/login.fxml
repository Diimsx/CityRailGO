<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox prefHeight="720" prefWidth="1280" styleClass="auth-root" stylesheets="@login.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">

    <!-- ===================== PANEL KIRI - BRANDING ===================== -->
    <VBox alignment="CENTER" prefHeight="720" prefWidth="480" styleClass="brand-panel">
        <VBox alignment="CENTER" spacing="18">

            <StackPane styleClass="brand-icon-circle">
                <FontIcon iconLiteral="fas-train" styleClass="brand-icon" />
            </StackPane>

            <VBox alignment="CENTER" spacing="6">
                <Label styleClass="brand-title" text="CityRailGO" />
                <Label styleClass="brand-subtitle" text="Pesan tiket kereta lebih cepat, lebih mudah" textAlignment="CENTER" wrapText="true" />
            </VBox>

            <VBox spacing="14" styleClass="feature-list">
                <HBox alignment="CENTER_LEFT" spacing="12" />
                <HBox alignment="CENTER_LEFT" spacing="12" />
                <HBox alignment="CENTER_LEFT" spacing="12" />
            </VBox>

        </VBox>
    </VBox>

    <!-- ===================== PANEL KANAN - FORM LOGIN ===================== -->
    <VBox alignment="CENTER" prefHeight="720" prefWidth="800" styleClass="form-panel">

        <VBox alignment="CENTER" maxWidth="380" spacing="22" styleClass="auth-card">

            <VBox alignment="CENTER" spacing="4">
                <Label styleClass="card-title" text="Selamat Datang" />
                <Label styleClass="card-subtitle" text="Masuk untuk melanjutkan ke CityRailGO" textAlignment="CENTER" wrapText="true" />
            </VBox>

            <VBox spacing="16">

                <VBox spacing="6">
                    <Label styleClass="field-label" text="Username" />
                    <StackPane>
                        <TextField fx:id="tfUsername" promptText="Masukkan username" styleClass="input-field" />
                        <FontIcon iconLiteral="fas-user" styleClass="input-icon" StackPane.alignment="CENTER_LEFT" />
                    </StackPane>
                </VBox>

                <VBox spacing="6">
                    <Label styleClass="field-label" text="Password" />
                    <StackPane>
                        <PasswordField fx:id="pfPassword" promptText="Masukkan password" styleClass="input-field" />
                        <FontIcon iconLiteral="fas-lock" styleClass="input-icon" StackPane.alignment="CENTER_LEFT" />
                    </StackPane>
                </VBox>

                <Label fx:id="lblError" maxWidth="380" styleClass="error-label" text="" visible="false" wrapText="true" />

                <Button fx:id="btnLogin" defaultButton="true" maxWidth="Infinity" onAction="#handleLogin" styleClass="btn-primary" text="Masuk">
                    <graphic>
                        <FontIcon iconLiteral="fas-sign-in-alt" styleClass="btn-icon" />
                    </graphic>
                </Button>

            </VBox>

            <HBox alignment="CENTER" spacing="4">
                <Label styleClass="footer-text" text="Belum punya akun?" />
                <Hyperlink onAction="#handleGoToRegister" styleClass="footer-link" text="Daftar di sini" />
            </HBox>

        </VBox>

        <Label styleClass="system-note" text="Sistem otomatis mendeteksi peran Anda (admin/penumpang) setelah login" />

    </VBox>

</HBox>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      alignment="CENTER"
      spacing="16"
      prefWidth="400" prefHeight="500"
      style="-fx-background-color: #f0f4ff; -fx-padding: 40;">

    <Label text="CityRailGO"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a3c8f;"/>

    <Label text="Sistem Pemesanan Tiket Kereta"
           style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>

    <VBox spacing="6" maxWidth="300">
        <Label text="Username" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
        <TextField fx:id="tfUsername"
                   promptText="Masukkan username"
                   prefWidth="300"
                   style="-fx-background-radius: 8; -fx-border-radius: 8;
                          -fx-border-color: #c0c8e8; -fx-padding: 8;"/>
    </VBox>

    <VBox spacing="6" maxWidth="300">
        <Label text="Password" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
        <PasswordField fx:id="pfPassword"
                       promptText="Masukkan password"
                       prefWidth="300"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;
                              -fx-border-color: #c0c8e8; -fx-padding: 8;"/>
    </VBox>

    <Label fx:id="lblError"
           text=""
           style="-fx-text-fill: #d32f2f; -fx-font-size: 12px;"
           visible="false"/>

    <Button fx:id="btnLogin"
            text="Login"
            onAction="#handleLogin"
            prefWidth="300" prefHeight="40"
            style="-fx-background-color: #1a3c8f; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-background-radius: 8; -fx-cursor: hand;"/>

    <HBox alignment="CENTER" spacing="4">
        <Label text="Belum punya akun?" style="-fx-font-size: 12px;"/>
        <Hyperlink text="Daftar di sini"
                   onAction="#handleGoToRegister"
                   style="-fx-font-size: 12px; -fx-text-fill: #1a3c8f;"/>
    </HBox>

</VBox>

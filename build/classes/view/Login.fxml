<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="view.controller.LoginController"
           styleClass="login-root"
           prefWidth="860" prefHeight="560">

    <stylesheets>
        <URL value="@../css/global.css"/>
        <URL value="@../css/login.css"/>
    </stylesheets>

    <!-- Split layout: kiri branding, kanan form -->
    <HBox>

        <!-- ── KIRI: Branding Panel ── -->
        <VBox HBox.hgrow="ALWAYS"
              alignment="CENTER"
              spacing="20"
              style="-fx-background-color: #1B3A7A; -fx-padding: 60;">

            <!-- Logo icon -->
            <VBox styleClass="login-logo-box" alignment="CENTER">
                <Label text="🚆" style="-fx-font-size: 26px;"/>
            </VBox>

            <Label text="CityRailGO"
                   style="-fx-font-size: 32px; -fx-font-weight: bold;
                          -fx-text-fill: #FFFFFF;"/>

            <Label text="Sistem Pemesanan Tiket Kereta"
                   style="-fx-font-size: 14px; -fx-text-fill: #93B4E8;"/>

            <VBox alignment="CENTER" spacing="12"
                  style="-fx-padding: 30 0 0 0;">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="✓" style="-fx-text-fill: #60A5FA; -fx-font-weight: bold;"/>
                    <Label text="Pesan tiket kapan saja"
                           style="-fx-text-fill: #CBD5E1; -fx-font-size: 13px;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="✓" style="-fx-text-fill: #60A5FA; -fx-font-weight: bold;"/>
                    <Label text="Pilih kursi favoritmu"
                           style="-fx-text-fill: #CBD5E1; -fx-font-size: 13px;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="✓" style="-fx-text-fill: #60A5FA; -fx-font-weight: bold;"/>
                    <Label text="Nikmati promo menarik"
                           style="-fx-text-fill: #CBD5E1; -fx-font-size: 13px;"/>
                </HBox>

            </VBox>

        </VBox>

        <!-- ── KANAN: Form Login ── -->
        <StackPane HBox.hgrow="ALWAYS"
                   alignment="CENTER"
                   style="-fx-background-color: #EEF2FB;">

            <VBox styleClass="login-card"
                  alignment="TOP_LEFT"
                  spacing="0">

                <!-- Header -->
                <Label text="Selamat Datang!" styleClass="login-title"/>
                <Label text="Masuk ke akun kamu untuk melanjutkan"
                       styleClass="login-subtitle"
                       style="-fx-padding: 6 0 24 0;"/>

                <!-- Divider -->
                <Pane styleClass="login-divider" maxWidth="1000"
                      style="-fx-padding: 0 0 24 0;"/>
                <VBox style="-fx-padding: 24 0 0 0;"/>

                <!-- Username -->
                <Label text="Username" styleClass="label-field"
                       style="-fx-padding: 0 0 6 0;"/>
                <TextField fx:id="tfUsername"
                           promptText="Masukkan username"
                           styleClass="text-field"
                           prefWidth="284"
                           style="-fx-pref-width: 284;"/>

                <VBox style="-fx-padding: 14 0 0 0;"/>

                <!-- Password -->
                <Label text="Password" styleClass="label-field"
                       style="-fx-padding: 0 0 6 0;"/>
                <PasswordField fx:id="pfPassword"
                               promptText="Masukkan password"
                               styleClass="password-field"
                               style="-fx-pref-width: 284;"/>

                <VBox style="-fx-padding: 12 0 0 0;"/>

                <!-- Error label -->
                <Label fx:id="lblError"
                       text=""
                       styleClass="label-error"
                       visible="false"
                       style="-fx-padding: 0 0 8 0;"/>

                <!-- Login Button -->
                <Button text="Masuk"
                        onAction="#handleLogin"
                        styleClass="btn-primary"
                        maxWidth="Infinity"
                        prefHeight="42"
                        style="-fx-padding: 0; -fx-max-width: 284; -fx-pref-width: 284;"/>

                <VBox style="-fx-padding: 20 0 0 0;"/>

                <!-- Divider -->
                <Pane styleClass="login-divider" maxWidth="1000"/>

                <VBox style="-fx-padding: 16 0 0 0;"/>

                <!-- Footer -->
                <HBox alignment="CENTER" spacing="4">
                    <Label text="Belum punya akun?"
                           styleClass="login-footer-text"/>
                    <Hyperlink text="Daftar sekarang"
                               onAction="#handleGoToRegister"
                               styleClass="login-footer-link"/>
                </HBox>

            </VBox>
        </StackPane>
    </HBox>
</StackPane>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.KelolaJadwalController"
            prefWidth="1280" prefHeight="720"
            stylesheets="@KelolaJadwal.css"
            styleClass="root-bg">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox prefWidth="240" prefHeight="720" styleClass="sidebar">

            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <FontIcon iconLiteral="fas-train" iconSize="26" styleClass="brand-icon"/>
                <Label text="CityRailGO" styleClass="brand-text"/>
                <Label text="Admin Panel" styleClass="brand-subtext"/>
            </VBox>

            <VBox styleClass="nav-list">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavDashboard">
                    <FontIcon iconLiteral="fas-th-large" styleClass="nav-icon"/>
                    <Label text="Dashboard" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavKereta">
                    <FontIcon iconLiteral="fas-train" styleClass="nav-icon"/>
                    <Label text="Kelola Kereta" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavRute">
                    <FontIcon iconLiteral="fas-route" styleClass="nav-icon"/>
                    <Label text="Kelola Rute" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavStasiun">
                    <FontIcon iconLiteral="fas-map-marker-alt" styleClass="nav-icon"/>
                    <Label text="Kelola Stasiun" styleClass="nav-label"/>
                </HBox>  
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item-active" onMouseClicked="#handleNavJadwal">
                    <FontIcon iconLiteral="fas-calendar-alt" styleClass="nav-icon-active"/>
                    <Label text="Kelola Jadwal" styleClass="nav-label-active"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavPromo">
                    <FontIcon iconLiteral="fas-percent" styleClass="nav-icon"/>
                    <Label text="Kelola Promo" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavLaporan">
                    <FontIcon iconLiteral="fas-chart-bar" styleClass="nav-icon"/>
                    <Label text="Laporan Penjualan" styleClass="nav-label"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="logout-item" onMouseClicked="#handleLogout">
                <FontIcon iconLiteral="fas-sign-out-alt" styleClass="logout-icon"/>
                <Label text="Logout" styleClass="logout-label"/>
            </HBox>

        </VBox>
    </left>

    <!-- ===================== KONTEN UTAMA ===================== -->
    <center>
        <StackPane>

            <VBox styleClass="content-area">

                <!-- Topbar -->
                <HBox alignment="CENTER_LEFT" styleClass="topbar">
                    <VBox>
                        <Label text="Kelola Jadwal" styleClass="page-title"/>
                        <Label text="Manajemen jadwal keberangkatan CityRailGO" styleClass="page-subtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblAdminName" text="Halo, Admin"/>
                </HBox>

                <!-- Toolbar: search + tambah -->
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="toolbar">
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-box">
                        <FontIcon iconLiteral="fas-search" styleClass="search-icon"/>
                        <TextField fx:id="tfSearch" promptText="Cari kereta atau rute..." styleClass="search-field"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnTambah" styleClass="btn-primary" onAction="#handleTambahJadwal">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <FontIcon iconLiteral="fas-plus" styleClass="btn-icon"/>
                                <Label text="Tambah Jadwal" styleClass="btn-label"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>

                <!-- Tabel jadwal -->
                <VBox spacing="14" styleClass="table-card" VBox.vgrow="ALWAYS">
                    <Label text="Daftar Jadwal" styleClass="card-title"/>
                    <TableView fx:id="tblJadwal" styleClass="jadwal-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNo"        text="No"        prefWidth="44"/>
                            <TableColumn fx:id="colKereta"    text="Kereta"    prefWidth="160"/>
                            <TableColumn fx:id="colRute"      text="Rute"      prefWidth="160"/>
                            <TableColumn fx:id="colJenisKelas" text="Kelas"    prefWidth="100"/>
                            <TableColumn fx:id="colBerangkat" text="Berangkat" prefWidth="135"/>
                            <TableColumn fx:id="colTiba"      text="Tiba"      prefWidth="135"/>
                            <TableColumn fx:id="colHarga"     text="Harga"     prefWidth="130"/>
                            <TableColumn fx:id="colStatus"    text="Status"    prefWidth="100"/>
                            <TableColumn fx:id="colAksi"      text="Aksi"      prefWidth="80"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <!-- ===================== MODAL TAMBAH/EDIT ===================== -->
            <StackPane fx:id="modalOverlay" styleClass="modal-backdrop" alignment="CENTER" visible="false" managed="false">
                <VBox styleClass="modal-card" maxWidth="460" maxHeight="700" spacing="14">
                    <padding>
                        <Insets top="24" right="28" bottom="24" left="28"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="lblModalTitle" text="Tambah Jadwal" styleClass="modal-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <FontIcon iconLiteral="fas-times" styleClass="modal-close-icon" onMouseClicked="#handleTutupModal"/>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="Kereta" styleClass="form-label"/>
                        <ComboBox fx:id="cbKereta" promptText="Pilih kereta" styleClass="form-field" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Rute" styleClass="form-label"/>
                        <ComboBox fx:id="cbRute" promptText="Pilih rute" styleClass="form-field" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Jenis Kelas" styleClass="form-label"/>
                        <ComboBox fx:id="cbJenisKelas" promptText="Pilih jenis kelas" styleClass="form-field" maxWidth="Infinity"/>
                    </VBox>

                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Tanggal Keberangkatan" styleClass="form-label"/>
                            <DatePicker fx:id="dpTanggal" styleClass="form-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Jam Berangkat (HH:mm)" styleClass="form-label"/>
                            <TextField fx:id="tfJamBerangkat" promptText="08:00" styleClass="form-field"/>
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="estimasi-box">
                        <FontIcon iconLiteral="fas-clock" styleClass="estimasi-icon"/>
                        <Label fx:id="lblEstimasiTiba" text="Estimasi tiba: —" styleClass="estimasi-label"/>
                    </HBox>

                    <!-- ===== PANEL PREVIEW HARGA LIVE ===== -->
                    <VBox fx:id="vboxHarga" styleClass="harga-panel" spacing="8" visible="false" managed="false">
                        <!-- Baris harga dasar -->
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Harga Dasar" styleClass="harga-label-muted"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblHargaDasar" text="Rp 0" styleClass="harga-value-muted"/>
                        </HBox>
                        <!-- Baris aturan aktif (dynamic pricing rules) -->
                        <VBox fx:id="vboxAturan" spacing="4"/>
                        <!-- Separator tipis -->
                        <Region styleClass="harga-separator"/>
                        <!-- Baris harga final -->
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Harga Final" styleClass="harga-label-final"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblHargaFinal" text="Rp 0" styleClass="harga-value-final"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Status" styleClass="form-label"/>
                        <ComboBox fx:id="cbStatus" promptText="Pilih status" styleClass="form-field" maxWidth="Infinity"/>
                    </VBox>

                    <Label fx:id="lblModalError" styleClass="modal-error" wrapText="true" visible="false" managed="false"/>

                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="Batal" styleClass="btn-secondary" onAction="#handleTutupModal"/>
                        <Button fx:id="btnSimpan" text="Simpan" styleClass="btn-primary" onAction="#handleSimpanJadwal"/>
                    </HBox>
                </VBox>
            </StackPane>

        </StackPane>
    </center>

</BorderPane>

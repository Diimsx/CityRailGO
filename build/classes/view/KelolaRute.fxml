<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.KelolaRuteController"
            prefWidth="1280" prefHeight="720"
            stylesheets="@KelolaRute.css"
            styleClass="root-bg">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox prefWidth="240" prefHeight="720" styleClass="sidebar">

            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <FontIcon iconLiteral="fas-train" iconSize="26" styleClass="brand-icon"/>
                <Label text="CityRailGO" styleClass="brand-text"/>
                <Label text="Admin Panel" styleClass="brand-subtext"/>
            </VBox>

            <VBox styleClass="nav-list">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavDashboard">
                    <FontIcon iconLiteral="fas-th-large" styleClass="nav-icon"/>
                    <Label text="Dashboard" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavKereta">
                    <FontIcon iconLiteral="fas-train" styleClass="nav-icon"/>
                    <Label text="Kelola Kereta" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item-active" onMouseClicked="#handleNavRute">
                    <FontIcon iconLiteral="fas-route" styleClass="nav-icon-active"/>
                    <Label text="Kelola Rute" styleClass="nav-label-active"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavStasiun">
                    <FontIcon iconLiteral="fas-map-marker-alt" styleClass="nav-icon"/>
                    <Label text="Kelola Stasiun" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavJadwal">
                    <FontIcon iconLiteral="fas-calendar-alt" styleClass="nav-icon"/>
                    <Label text="Kelola Jadwal" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavPromo">
                    <FontIcon iconLiteral="fas-percent" styleClass="nav-icon"/>
                    <Label text="Kelola Promo" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavLaporan">
                    <FontIcon iconLiteral="fas-chart-bar" styleClass="nav-icon"/>
                    <Label text="Laporan Penjualan" styleClass="nav-label"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="logout-item" onMouseClicked="#handleLogout">
                <FontIcon iconLiteral="fas-sign-out-alt" styleClass="logout-icon"/>
                <Label text="Logout" styleClass="logout-label"/>
            </HBox>

        </VBox>
    </left>

    <!-- ===================== KONTEN UTAMA ===================== -->
    <center>
        <StackPane>

            <VBox styleClass="content-area">

                <!-- Topbar -->
                <HBox alignment="CENTER_LEFT" styleClass="topbar">
                    <VBox>
                        <Label text="Kelola Rute" styleClass="page-title"/>
                        <Label text="Manajemen data rute perjalanan CityRailGO" styleClass="page-subtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblAdminName" text="Halo, Admin" styleClass="admin-name"/>
                </HBox>

                <!-- Toolbar: search + tambah -->
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="toolbar">
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-box">
                        <FontIcon iconLiteral="fas-search" styleClass="search-icon"/>
                        <TextField fx:id="tfSearch" promptText="Cari nama atau stasiun rute..." styleClass="search-field"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnTambah" styleClass="btn-primary" onAction="#handleTambahRute">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <FontIcon iconLiteral="fas-plus" styleClass="btn-icon"/>
                                <Label text="Buat Rute Baru" styleClass="btn-label"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>

                <!-- Tabel rute -->
                <VBox spacing="14" styleClass="table-card" VBox.vgrow="ALWAYS">
                    <Label text="Daftar Rute" styleClass="card-title"/>
                    <TableView fx:id="tblRute" styleClass="rute-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNo"       text="No"         prefWidth="46"/>
                            <TableColumn fx:id="colNamaRute" text="Nama Rute"  prefWidth="180"/>
                            <TableColumn fx:id="colRute"     text="Urutan Stasiun" prefWidth="360"/>
                            <TableColumn fx:id="colJarak"    text="Jarak"      prefWidth="100"/>
                            <TableColumn fx:id="colEstimasi" text="Estimasi"   prefWidth="130"/>
                            <TableColumn fx:id="colAksi"     text="Aksi"       prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <!-- ===================== MODAL TAMBAH/EDIT (Scrollable) ===================== -->
            <StackPane fx:id="modalOverlay" styleClass="modal-backdrop" alignment="CENTER"
                       visible="false" managed="false">

                <VBox styleClass="modal-card-tall" maxHeight="640" spacing="0">

                    <!-- Header modal (fixed, tidak scroll) -->
                    <HBox alignment="CENTER_LEFT" spacing="0">
                        <padding><Insets top="22" right="24" bottom="16" left="24"/></padding>
                        <Label fx:id="lblModalTitle" text="Buat Rute Baru" styleClass="modal-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <FontIcon iconLiteral="fas-times" styleClass="modal-close-icon" onMouseClicked="#handleTutupModal"/>
                    </HBox>

                    <!-- Body modal yang bisa di-scroll -->
                    <ScrollPane styleClass="modal-scroll" VBox.vgrow="ALWAYS"
                                fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                        <VBox spacing="16">
                            <padding><Insets top="0" right="24" bottom="16" left="24"/></padding>

                            <!-- Nama Rute -->
                            <VBox spacing="6">
                                <Label text="Nama Rute" styleClass="form-label"/>
                                <TextField fx:id="tfNamaRute" promptText="Contoh: Jalur Utara Premium" styleClass="form-field"/>
                            </VBox>

                            <!-- Stasiun Asal & Tujuan (2 kolom) -->
                            <HBox spacing="12">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="Stasiun Asal" styleClass="form-label"/>
                                    <ComboBox fx:id="cbStasiunAsal" promptText="Pilih stasiun awal..."
                                              styleClass="form-field" maxWidth="Infinity"/>
                                </VBox>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="Stasiun Tujuan (Akhir)" styleClass="form-label"/>
                                    <ComboBox fx:id="cbStasiunTujuan" promptText="Pilih stasiun akhir..."
                                              styleClass="form-field" maxWidth="Infinity"/>
                                </VBox>
                            </HBox>

                            <!-- Jarak & Estimasi - AUTO-GENERATE -->
                            <VBox spacing="8" styleClass="auto-calc-panel">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <FontIcon iconLiteral="fas-calculator" styleClass="auto-calc-icon"/>
                                    <Label text="Jarak &amp; Estimasi Waktu" styleClass="auto-calc-title"/>
                                    <Label text="(otomatis)" styleClass="auto-calc-badge"/>
                                </HBox>
                                <HBox spacing="12">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Jarak Total" styleClass="form-label"/>
                                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="auto-calc-field">
                                            <FontIcon iconLiteral="fas-road" styleClass="auto-calc-field-icon"/>
                                            <Label fx:id="lblJarakKm" text="-- km" styleClass="auto-calc-value"/>
                                        </HBox>
                                        <TextField fx:id="tfJarakKm" visible="false" managed="false"/>
                                    </VBox>
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Estimasi Waktu" styleClass="form-label"/>
                                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="auto-calc-field">
                                            <FontIcon iconLiteral="fas-clock" styleClass="auto-calc-field-icon"/>
                                            <Label fx:id="lblEstimasiMenit" text="-- jam" styleClass="auto-calc-value"/>
                                        </HBox>
                                        <TextField fx:id="tfEstimasiMenit" visible="false" managed="false"/>
                                    </VBox>
                                </HBox>
                                <Label fx:id="lblAutoCalcHint" text="Pilih stasiun asal dan tujuan untuk menghitung otomatis." styleClass="auto-calc-hint" wrapText="true"/>
                            </VBox>

                            <!-- Section Stasiun Pemberhentian -->
                            <VBox spacing="10">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Stasiun Pemberhentian (Transit)" styleClass="stops-section-label"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button styleClass="btn-add-stop" onAction="#handleTambahStop">
                                        <graphic>
                                            <HBox alignment="CENTER" spacing="6">
                                                <FontIcon iconLiteral="fas-plus" styleClass="btn-add-stop-icon"/>
                                                <Label text="Tambah Pemberhentian" styleClass="btn-add-stop-label"
                                                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#167A42;"/>
                                            </HBox>
                                        </graphic>
                                    </Button>
                                </HBox>

                                <!-- Container baris stop dinamis -->
                                <VBox fx:id="vboxStops" styleClass="stops-container" spacing="8">
                                    <!-- Baris ComboBox ditambah secara dinamis via controller -->
                                </VBox>

                                <Label text="Urutan 1 = Stasiun Asal, pemberhentian ditengah, urutan terakhir = Stasiun Tujuan."
                                       styleClass="form-hint" wrapText="true"/>
                            </VBox>

                            <!-- Error label -->
                            <Label fx:id="lblModalError" styleClass="modal-error"
                                   wrapText="true" visible="false" managed="false"/>

                        </VBox>
                    </ScrollPane>

                    <!-- Footer modal (fixed, tidak scroll) -->
                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <padding><Insets top="14" right="24" bottom="20" left="24"/></padding>
                        <Button text="Batal" styleClass="btn-secondary" onAction="#handleTutupModal"/>
                        <Button fx:id="btnSimpan" text="Simpan" styleClass="btn-primary" onAction="#handleSimpanRute"/>
                    </HBox>

                </VBox>
            </StackPane>

        </StackPane>
    </center>

</BorderPane>

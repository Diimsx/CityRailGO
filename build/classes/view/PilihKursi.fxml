<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PilihKursiController"
            prefWidth="1280" prefHeight="720"
            stylesheets="@PilihKursi.css"
            styleClass="root-bg">

    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header-bar">
            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="btn-kembali" onMouseClicked="#handleKembali">
                <FontIcon iconLiteral="fas-arrow-left" styleClass="kembali-icon"/>
                <Label text="Kembali" styleClass="kembali-label"/>
            </HBox>
            <Region styleClass="header-divider"/>
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="brand-box-h">
                <FontIcon iconLiteral="fas-train" iconSize="22" styleClass="brand-icon"/>
                <VBox spacing="0">
                    <Label text="CityRailGO" styleClass="brand-text-h"/>
                    <Label text="Portal Penumpang" styleClass="brand-subtext"/>
                </VBox>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="10" styleClass="user-badge-h">
                <FontIcon fx:id="topbarIcon" iconLiteral="fas-user-circle" styleClass="nav-icon-h"/>
                <ImageView fx:id="topbarAvatar" visible="false" managed="false"/>
                <Label fx:id="lblNama" text="Penumpang" styleClass="user-name-h"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <BorderPane>
            <top>
                <VBox>
                    <HBox alignment="CENTER_LEFT" styleClass="topbar">
                        <VBox>
                            <Label text="Pilih Kursi" styleClass="page-title"/>
                            <Label text="Klik kursi yang tersedia untuk memilih tempat duduk Anda" styleClass="page-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox styleClass="summary-card" spacing="24" alignment="CENTER_LEFT">
                        <padding><Insets top="20" right="28" bottom="20" left="28"/></padding>
                        <VBox spacing="4">
                            <Label fx:id="lblKereta" text="—" styleClass="summary-kereta"/>
                            <Label fx:id="lblKelas" text="—" styleClass="summary-rute"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="lblJamBerangkat" text="—" styleClass="summary-waktu"/>
                            <Label fx:id="lblAsalRute" text="—" styleClass="summary-stasiun"/>
                        </VBox>
                        <FontIcon iconLiteral="fas-arrow-right" styleClass="arrow-icon"/>
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="lblJamTiba" text="—" styleClass="summary-waktu"/>
                            <Label fx:id="lblTujuanRute" text="—" styleClass="summary-stasiun"/>
                        </VBox>
                        <Region style="-fx-background-color:#1B3A6B; -fx-min-width:1; -fx-max-width:1; -fx-min-height:50;"/>
                        <VBox spacing="2" alignment="CENTER_RIGHT">
                            <Label fx:id="lblHarga" text="—" styleClass="summary-harga"/>
                            <Label text="per kursi" styleClass="summary-harga-label"/>
                        </VBox>
                    </HBox>
                </VBox>
            </top>

            <center>
                <ScrollPane styleClass="content-scroll"
                            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                    <VBox spacing="20">
                        <padding><Insets top="24" right="28" bottom="16" left="28"/></padding>

                        <HBox styleClass="legend-box" spacing="24" alignment="CENTER_LEFT">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Region styleClass="legend-item-tersedia"/>
                                <Label text="Tersedia" styleClass="legend-label"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Region styleClass="legend-item-terisi"/>
                                <Label text="Terisi" styleClass="legend-label"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Region styleClass="legend-item-dipilih"/>
                                <Label text="Dipilih" styleClass="legend-label"/>
                            </HBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblSisaKursi" text="— kursi tersedia" styleClass="legend-label"
                                   style="-fx-font-weight:bold; -fx-text-fill:#2BB673;"/>
                        </HBox>

                        <VBox styleClass="seat-map-card" spacing="16">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontIcon iconLiteral="fas-couch" style="-fx-icon-size:16; -fx-icon-color:#4D8AFF;"/>
                                <VBox spacing="2">
                                    <Label text="Denah Tempat Duduk" styleClass="seat-map-title"/>
                                    <Label text="Klik kursi untuk memilih. Nomor kursi ditampilkan pada setiap kotak." styleClass="seat-map-hint"/>
                                </VBox>
                            </HBox>
                             <HBox fx:id="hboxCarriageSelector" spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 8 0 8 0;"/>

                             <VBox fx:id="vboxSeatMap" spacing="6" alignment="CENTER"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </center>

            <bottom>
                <HBox styleClass="footer-bar" alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="3">
                        <Label fx:id="lblKursiDipilih" text="Belum ada kursi dipilih" styleClass="selected-seat-info"/>
                        <Label fx:id="lblInfoKursi" text="Pilih kursi dari denah di atas" styleClass="selected-seat-hint"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnLanjut" styleClass="btn-lanjut-disabled" onAction="#handleLanjutPembayaran" disable="true">
                        <graphic>
                            <HBox alignment="CENTER" spacing="10">
                                <Label fx:id="lblBtnLanjut" text="Pilih kursi terlebih dahulu"
                                       style="-fx-text-fill:#9CACC4; -fx-font-size:14px; -fx-font-weight:bold;"/>
                                <FontIcon fx:id="iconBtnLanjut" iconLiteral="fas-arrow-right"
                                          style="-fx-icon-size:14; -fx-icon-color:#9CACC4;"
                                          visible="false" managed="false"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>
            </bottom>
        </BorderPane>
    </center>

</BorderPane>

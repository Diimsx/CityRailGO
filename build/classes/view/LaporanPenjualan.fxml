<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.LaporanPenjualanController"
            prefWidth="1280" prefHeight="720"
            stylesheets="@LaporanPenjualan.css"
            styleClass="root-bg">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox prefWidth="240" prefHeight="720" styleClass="sidebar">

            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <FontIcon iconLiteral="fas-train" iconSize="26" styleClass="brand-icon"/>
                <Label text="CityRailGO" styleClass="brand-text"/>
                <Label text="Admin Panel" styleClass="brand-subtext"/>
            </VBox>

            <VBox styleClass="nav-list">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavDashboard">
                    <FontIcon iconLiteral="fas-th-large" styleClass="nav-icon"/>
                    <Label text="Dashboard" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavKereta">
                    <FontIcon iconLiteral="fas-train" styleClass="nav-icon"/>
                    <Label text="Kelola Kereta" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavRute">
                    <FontIcon iconLiteral="fas-route" styleClass="nav-icon"/>
                    <Label text="Kelola Rute" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavStasiun">
                    <FontIcon iconLiteral="fas-map-marker-alt" styleClass="nav-icon"/>
                    <Label text="Kelola Stasiun" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavJadwal">
                    <FontIcon iconLiteral="fas-calendar-alt" styleClass="nav-icon"/>
                    <Label text="Kelola Jadwal" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavPromo">
                    <FontIcon iconLiteral="fas-percent" styleClass="nav-icon"/>
                    <Label text="Kelola Promo" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item-active" onMouseClicked="#handleNavLaporan">
                    <FontIcon iconLiteral="fas-chart-bar" styleClass="nav-icon-active"/>
                    <Label text="Laporan Penjualan" styleClass="nav-label-active"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="logout-item" onMouseClicked="#handleLogout">
                <FontIcon iconLiteral="fas-sign-out-alt" styleClass="logout-icon"/>
                <Label text="Logout" styleClass="logout-label"/>
            </HBox>

        </VBox>
    </left>

    <!-- ===================== KONTEN UTAMA ===================== -->
    <center>
        <VBox styleClass="content-area">

            <!-- Topbar -->
            <HBox alignment="CENTER_LEFT" styleClass="topbar">
                <VBox>
                    <Label text="Laporan Penjualan" styleClass="page-title"/>
                    <Label text="Rekap transaksi tiket CityRailGO" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblAdminName" text="Halo, Admin" styleClass="admin-name"/>
            </HBox>

            <!-- Stat KPI cards (mengikuti hasil filter) -->
            <HBox spacing="16" styleClass="stat-row">

                <VBox alignment="CENTER_LEFT" spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="fas-receipt" styleClass="stat-icon icon-blue"/>
                    <Label fx:id="lblTotalTransaksi" text="0" styleClass="stat-value"/>
                    <Label text="Total Transaksi" styleClass="stat-label"/>
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="fas-money-bill-wave" styleClass="stat-icon icon-green"/>
                    <Label fx:id="lblTotalPendapatan" text="Rp 0" styleClass="stat-value stat-value-income"/>
                    <Label text="Total Pendapatan" styleClass="stat-label"/>
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="fas-check-circle" styleClass="stat-icon icon-purple"/>
                    <Label fx:id="lblTiketAktif" text="0" styleClass="stat-value"/>
                    <Label text="Tiket Aktif" styleClass="stat-label"/>
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="6" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="fas-times-circle" styleClass="stat-icon icon-red"/>
                    <Label fx:id="lblTiketDibatalkan" text="0" styleClass="stat-value"/>
                    <Label text="Tiket Dibatalkan" styleClass="stat-label"/>
                </VBox>

            </HBox>

            <!-- Toolbar filter -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="toolbar">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-box">
                    <FontIcon iconLiteral="fas-search" styleClass="search-icon"/>
                    <TextField fx:id="tfSearch" promptText="Cari kode tiket, penumpang, kereta, rute..." styleClass="search-field"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="date-range-box">
                    <FontIcon iconLiteral="fas-calendar-alt" styleClass="search-icon"/>
                    <DatePicker fx:id="dpDari" promptText="Dari" styleClass="date-range-field"/>
                    <Label text="-" styleClass="date-range-separator"/>
                    <DatePicker fx:id="dpSampai" promptText="Sampai" styleClass="date-range-field"/>
                </HBox>

                <ComboBox fx:id="cbStatusFilter" promptText="Semua Status" styleClass="filter-field"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Reset" styleClass="btn-secondary" onAction="#handleResetFilter"/>

                <!-- Toggle Breakdown -->
                <HBox styleClass="toggle-group" spacing="0">
                    <Button fx:id="btnToggleHarian" text="Harian" styleClass="toggle-btn-active" onAction="#handleToggleHarian"/>
                    <Button fx:id="btnToggleBulanan" text="Bulanan" styleClass="toggle-btn" onAction="#handleToggleBulanan"/>
                </HBox>

                <Button fx:id="btnExport" styleClass="btn-export" onAction="#handleExportCsv">
                    <graphic>
                        <HBox alignment="CENTER" spacing="8">
                            <FontIcon iconLiteral="fas-file-csv" styleClass="btn-icon"/>
                            <Label text="Export CSV" styleClass="btn-label"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

            <!-- Layout bawah: Tabel + Panel Breakdown berdampingan -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <!-- Tabel Transaksi -->
                <VBox spacing="12" styleClass="table-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Rincian Transaksi" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblJumlahTampil" text="0 tiket ditampilkan" styleClass="jumlah-tampil"/>
                    </HBox>
                    <TableView fx:id="tblLaporan" styleClass="laporan-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNo"         text="No"        prefWidth="40"/>
                            <TableColumn fx:id="colKodeTiket"  text="Kode"      prefWidth="95"/>
                            <TableColumn fx:id="colPenumpang"  text="Penumpang" prefWidth="130"/>
                            <TableColumn fx:id="colKereta"     text="Kereta"    prefWidth="120"/>
                            <TableColumn fx:id="colRute"       text="Rute"      prefWidth="140"/>
                            <TableColumn fx:id="colBerangkat"  text="Berangkat" prefWidth="115"/>
                            <TableColumn fx:id="colHarga"      text="Harga"     prefWidth="105"/>
                            <TableColumn fx:id="colStatus"     text="Status"    prefWidth="90"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Panel Breakdown Harian/Bulanan -->
                <VBox spacing="12" styleClass="breakdown-card" prefWidth="260">
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="lblBreakdownTitle" text="Breakdown Harian" styleClass="card-title"/>
                    </HBox>
                    <Label fx:id="lblBreakdownSubtitle" text="Pendapatan per hari" styleClass="breakdown-subtitle"/>

                    <!-- Scrollable list breakdown rows -->
                    <VBox fx:id="vboxBreakdown" spacing="6" VBox.vgrow="ALWAYS" styleClass="breakdown-list">
                        <!-- Baris diisi secara dinamis dari controller -->
                    </VBox>

                    <!-- Footer total breakdown -->
                    <VBox styleClass="breakdown-footer" spacing="4">
                        <Label styleClass="breakdown-footer-label" text="Total Periode Ini"/>
                        <Label fx:id="lblBreakdownTotal" text="Rp 0" styleClass="breakdown-footer-value"/>
                    </VBox>
                </VBox>

            </HBox>

        </VBox>
    </center>

</BorderPane>

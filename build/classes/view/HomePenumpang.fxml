<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.HomePenumpangController"
            prefWidth="1280" prefHeight="720"
            style="-fx-background-color: #f0f4ff;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #0d1b3e; -fx-padding: 16 30 16 30;">
            <Label text="CityRailGO"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblNama" text="Halo, Penumpang"
                   style="-fx-font-size: 14px; -fx-text-fill: #cfd9f2;"/>
            <Button text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color: #2979ff; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 6 16 6 16;"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="30" style="-fx-padding: 60 0 0 0;">

            <Label text="Mau ke mana hari ini?"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a3c8f;"/>

            <HBox alignment="CENTER" spacing="24">

                <VBox alignment="CENTER" spacing="10"
                      prefWidth="280" prefHeight="180"
                      onMouseClicked="#handleCariTiket"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #c0c8e8; -fx-border-radius: 12;
                             -fx-cursor: hand;">
                    <Label text="Cari Tiket"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a3c8f;"/>
                    <Label text="Cari jadwal dan pesan tiket kereta"
                           wrapText="true" maxWidth="220" textAlignment="CENTER"
                           style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="10"
                      prefWidth="280" prefHeight="180"
                      onMouseClicked="#handleRiwayatTiket"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #c0c8e8; -fx-border-radius: 12;
                             -fx-cursor: hand;">
                    <Label text="Riwayat Tiket"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a3c8f;"/>
                    <Label text="Lihat tiket yang pernah dibeli"
                           wrapText="true" maxWidth="220" textAlignment="CENTER"
                           style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                </VBox>

            </HBox>
        </VBox>
    </center>
</BorderPane>

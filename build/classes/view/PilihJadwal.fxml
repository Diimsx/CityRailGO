<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PilihJadwalController"
            prefWidth="1280" prefHeight="720"
            stylesheets="@PilihJadwal.css"
            styleClass="root-bg">

    <!-- Sidebar -->
    <left>
        <VBox prefWidth="240" prefHeight="720" styleClass="sidebar">
            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <FontIcon iconLiteral="fas-train" iconSize="26" styleClass="brand-icon"/>
                <Label text="CityRailGO" styleClass="brand-text"/>
                <Label text="Portal Penumpang" styleClass="brand-subtext"/>
            </VBox>
            <VBox styleClass="nav-list">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavBeranda">
                    <FontIcon iconLiteral="fas-home" styleClass="nav-icon"/>
                    <Label text="Beranda" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item-active">
                    <FontIcon iconLiteral="fas-search" styleClass="nav-icon-active"/>
                    <Label text="Cari Jadwal" styleClass="nav-label-active"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavTiketSaya">
                    <FontIcon iconLiteral="fas-ticket-alt" styleClass="nav-icon"/>
                    <Label text="Tiket Saya" styleClass="nav-label"/>
                </HBox>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="logout-item" onMouseClicked="#handleLogout">
                <FontIcon iconLiteral="fas-sign-out-alt" styleClass="logout-icon"/>
                <Label text="Logout" styleClass="logout-label"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox>
            <!-- Topbar -->
            <HBox alignment="CENTER_LEFT" styleClass="topbar">
                <VBox>
                    <Label text="Pilih Jadwal" styleClass="page-title"/>
                    <Label text="Hasil pencarian jadwal kereta sesuai kriteria Anda" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="10" styleClass="user-badge">
                    <FontIcon fx:id="topbarIcon" iconLiteral="fas-user-circle" styleClass="nav-icon"/>
                    <ImageView fx:id="topbarAvatar" visible="false" managed="false"/>
                    <Label fx:id="lblNama" text="Penumpang" styleClass="user-name"/>
                </HBox>
            </HBox>

            <!-- Filter Info Bar -->
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="filter-bar">
                <VBox spacing="2">
                    <Label text="RUTE" styleClass="filter-label"/>
                    <Label fx:id="lblRute" text="— → —" styleClass="filter-value"/>
                </VBox>
                <VBox styleClass="hero-divider" style="-fx-background-color:#EDF1F7; -fx-min-width:1; -fx-max-width:1; -fx-min-height:30;"/>
                <VBox spacing="2">
                    <Label text="TANGGAL" styleClass="filter-label"/>
                    <Label fx:id="lblTanggal" text="—" styleClass="filter-value"/>
                </VBox>
                <VBox styleClass="hero-divider" style="-fx-background-color:#EDF1F7; -fx-min-width:1; -fx-max-width:1; -fx-min-height:30;"/>
                <VBox spacing="2">
                    <Label text="PENUMPANG" styleClass="filter-label"/>
                    <Label fx:id="lblJumlahPenumpang" text="1 Orang" styleClass="filter-value"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button styleClass="btn-back" onAction="#handleNavBeranda">
                    <graphic>
                        <HBox alignment="CENTER" spacing="8">
                            <FontIcon iconLiteral="fas-arrow-left" styleClass="btn-back-icon"/>
                            <Label text="Ubah Pencarian" style="-fx-text-fill:#0A192F; -fx-font-size:13px;"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>

            <!-- Results -->
            <ScrollPane styleClass="content-scroll" VBox.vgrow="ALWAYS"
                        fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
                <VBox spacing="16">
                    <padding><Insets top="24" right="28" bottom="28" left="28"/></padding>

                    <!-- Header hasil -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblJumlahHasil" text="Menampilkan jadwal..." styleClass="section-title"/>
                        <Label fx:id="lblCountHasil" text="" styleClass="section-count"/>
                    </HBox>

                    <!-- Container cards jadwal (isi dinamis dari controller) -->
                    <VBox fx:id="vboxHasil" spacing="12"/>

                    <!-- Empty state (tersembunyi) -->
                    <VBox fx:id="paneKosong" alignment="CENTER" spacing="16"
                          visible="false" managed="false" style="-fx-padding: 60 0 60 0;">
                        <FontIcon iconLiteral="fas-train" styleClass="empty-icon"/>
                        <Label text="Tidak Ada Jadwal" styleClass="empty-title"/>
                        <Label text="Tidak ditemukan jadwal untuk rute dan tanggal yang dipilih." styleClass="empty-subtitle" wrapText="true"/>
                        <Button text="Ubah Pencarian" styleClass="btn-pilih" onAction="#handleNavBeranda"/>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>

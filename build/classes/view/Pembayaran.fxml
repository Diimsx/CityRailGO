<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PembayaranController"
            prefWidth="1280" prefHeight="720"
            stylesheets="@Pembayaran.css"
            styleClass="root-bg">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" styleClass="header-bar">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="btn-kembali" onMouseClicked="#handleKembali">
                    <FontIcon iconLiteral="fas-arrow-left" styleClass="kembali-icon"/>
                    <Label text="Kembali" styleClass="kembali-label"/>
                </HBox>
                <Region styleClass="header-divider"/>
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="brand-box-h">
                    <FontIcon iconLiteral="fas-train" iconSize="22" styleClass="brand-icon"/>
                    <VBox spacing="0">
                        <Label text="CityRailGO" styleClass="brand-text-h"/>
                        <Label text="Portal Penumpang" styleClass="brand-subtext"/>
                    </VBox>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="10" styleClass="user-badge-h">
                    <FontIcon fx:id="topbarIcon" iconLiteral="fas-user-circle" styleClass="nav-icon-h"/>
                    <ImageView fx:id="topbarAvatar" visible="false" managed="false"/>
                    <Label fx:id="lblNama" text="Penumpang" styleClass="user-name-h"/>
                </HBox>
            </HBox>

            <HBox alignment="CENTER" spacing="8" styleClass="step-bar">
                <StackPane styleClass="step-done">
                    <FontIcon iconLiteral="fas-check" style="-fx-icon-size:12; -fx-icon-color:white;"/>
                </StackPane>
                <VBox alignment="CENTER"><Label text="Pilih Jadwal" styleClass="step-label"/></VBox>
                <Region styleClass="step-line-done"/>
                <StackPane styleClass="step-done">
                    <FontIcon iconLiteral="fas-check" style="-fx-icon-size:12; -fx-icon-color:white;"/>
                </StackPane>
                <VBox alignment="CENTER"><Label text="Data Penumpang" styleClass="step-label"/></VBox>
                <Region styleClass="step-line-done"/>
                <StackPane styleClass="step-done">
                    <FontIcon iconLiteral="fas-check" style="-fx-icon-size:12; -fx-icon-color:white;"/>
                </StackPane>
                <VBox alignment="CENTER"><Label text="Pilih Kursi" styleClass="step-label"/></VBox>
                <Region styleClass="step-line-done"/>
                <StackPane styleClass="step-active">
                    <Label text="4"/>
                </StackPane>
                <VBox alignment="CENTER"><Label text="Pembayaran" styleClass="step-label-active"/></VBox>
                <Region styleClass="step-line"/>
                <StackPane styleClass="step-inactive">
                    <Label text="5"/>
                </StackPane>
                <VBox alignment="CENTER"><Label text="Selesai" styleClass="step-label"/></VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane styleClass="content-scroll"
                    fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox spacing="20">
                <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

                <VBox spacing="4">
                    <Label text="Pembayaran" styleClass="page-title"/>
                    <Label text="Isi data diri dan pilih metode pembayaran" styleClass="page-subtitle"/>
                </VBox>

                <HBox spacing="24">
                    <VBox spacing="16" prefWidth="420" minWidth="360">

                        <VBox styleClass="summary-card" spacing="16">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontIcon iconLiteral="fas-ticket-alt" styleClass="card-icon"/>
                                <Label text="Ringkasan Pemesanan" styleClass="card-title"/>
                            </HBox>
                            <Region styleClass="divider-h"/>

                            <HBox><Label text="Kereta" styleClass="detail-label" prefWidth="140"/>
                                <Label fx:id="lblSumKereta" text="—" styleClass="detail-value"/></HBox>
                            <HBox><Label text="Kelas" styleClass="detail-label" prefWidth="140"/>
                                <Label fx:id="lblSumKelas" text="—" styleClass="detail-value"/></HBox>
                            <HBox><Label text="Rute" styleClass="detail-label" prefWidth="140"/>
                                <Label fx:id="lblSumRute" text="—" styleClass="detail-value" wrapText="true"/></HBox>
                            <HBox><Label text="Tanggal" styleClass="detail-label" prefWidth="140"/>
                                <Label fx:id="lblSumTanggal" text="—" styleClass="detail-value"/></HBox>
                            <HBox><Label text="Waktu" styleClass="detail-label" prefWidth="140"/>
                                <Label fx:id="lblSumWaktu" text="—" styleClass="detail-value"/></HBox>
                            <HBox><Label text="Nomor Kursi" styleClass="detail-label" prefWidth="140"/>
                                <Label fx:id="lblSumKursi" text="—" styleClass="detail-value"/></HBox>

                            <Region styleClass="divider-h"/>

                            <VBox fx:id="vboxBreakdownHarga" spacing="8" styleClass="harga-row"/>
                        </VBox>

                        <VBox styleClass="summary-card" spacing="12">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontIcon iconLiteral="fas-tags" styleClass="card-icon"/>
                                <Label text="Kode Promo" styleClass="card-title"/>
                            </HBox>
                            <Region styleClass="divider-h"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <TextField fx:id="tfPromo" promptText="Contoh: PROMO50" styleClass="form-field" HBox.hgrow="ALWAYS" style="-fx-pref-height:36;"/>
                                <Button text="Gunakan" onAction="#handleApplyPromo" styleClass="btn-back" style="-fx-background-color:#4D8AFF; -fx-text-fill:white; -fx-border-color:transparent; -fx-padding:8 14 8 14;"/>
                            </HBox>
                            <Label fx:id="lblPromoStatus" text="" visible="false" managed="false" wrapText="true"/>
                        </VBox>
                    </VBox>

                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <VBox fx:id="vboxManifes" styleClass="form-card" spacing="16">
                        </VBox>

                        <VBox styleClass="form-card" spacing="16">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontIcon iconLiteral="fas-credit-card" styleClass="card-icon"/>
                                <Label text="Metode Pembayaran" styleClass="card-title"/>
                            </HBox>
                            <Region styleClass="divider-h"/>

                            <HBox spacing="12">
                                <Button fx:id="btnTransfer" styleClass="btn-metode" onAction="#handlePilihMetode"
                                        userData="Transfer Bank" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="6">
                                            <FontIcon iconLiteral="fas-credit-card" styleClass="metode-icon"
                                                      style="-fx-icon-color:#4D8AFF;"/>
                                            <Label text="Transfer Bank" style="-fx-font-size:12px; -fx-font-weight:bold;"/>
                                        </VBox>
                                    </graphic>
                                </Button>
                                <Button fx:id="btnQris" styleClass="btn-metode" onAction="#handlePilihMetode"
                                        userData="QRIS" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="6">
                                            <FontIcon iconLiteral="fas-mobile-alt" styleClass="metode-icon"
                                                      style="-fx-icon-color:#4D8AFF;"/>
                                            <Label text="QRIS" style="-fx-font-size:12px; -fx-font-weight:bold;"/>
                                        </VBox>
                                    </graphic>
                                </Button>
                                <Button fx:id="btnTunai" styleClass="btn-metode" onAction="#handlePilihMetode"
                                        userData="Tunai" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                    <graphic>
                                        <VBox alignment="CENTER" spacing="6">
                                            <FontIcon iconLiteral="fas-wallet" styleClass="metode-icon"
                                                      style="-fx-icon-color:#4D8AFF;"/>
                                            <Label text="Tunai" style="-fx-font-size:12px; -fx-font-weight:bold;"/>
                                        </VBox>
                                    </graphic>
                                </Button>
                            </HBox>

                            <Label fx:id="lblMetodeDipilih" text="Pilih metode pembayaran di atas"
                                   styleClass="form-hint" wrapText="true"/>
                        </VBox>

                        <Label fx:id="lblError" text="" styleClass="error-label"
                               visible="false" managed="false" wrapText="true"/>

                        <Button styleClass="btn-konfirmasi" maxWidth="Infinity"
                                onAction="#handleKonfirmasiPembayaran">
                            <graphic>
                                <HBox alignment="CENTER" spacing="12">
                                    <FontIcon iconLiteral="fas-check-circle" styleClass="btn-konfirmasi-icon"/>
                                    <Label text="Konfirmasi &amp; Bayar"
                                           style="-fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold;"/>
                                </HBox>
                            </graphic>
                        </Button>

                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

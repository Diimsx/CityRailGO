<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.KelolaKeretaController"
            prefWidth="1280" prefHeight="720"
            stylesheets="@KelolaKereta.css"
            styleClass="root-bg">

    <left>
        <VBox prefWidth="240" prefHeight="720" styleClass="sidebar">

            <VBox alignment="CENTER" spacing="4" styleClass="brand-box">
                <FontIcon iconLiteral="fas-train" iconSize="26" styleClass="brand-icon"/>
                <Label text="CityRailGO" styleClass="brand-text"/>
                <Label text="Admin Panel" styleClass="brand-subtext"/>
            </VBox>

            <VBox styleClass="nav-list">
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavDashboard">
                    <FontIcon iconLiteral="fas-th-large" styleClass="nav-icon"/>
                    <Label text="Dashboard" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item-active" onMouseClicked="#handleNavKereta">
                    <FontIcon iconLiteral="fas-train" styleClass="nav-icon-active"/>
                    <Label text="Kelola Kereta" styleClass="nav-label-active"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavRute">
                    <FontIcon iconLiteral="fas-route" styleClass="nav-icon"/>
                    <Label text="Kelola Rute" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavStasiun">
                    <FontIcon iconLiteral="fas-map-marker-alt" styleClass="nav-icon"/>
                    <Label text="Kelola Stasiun" styleClass="nav-label"/>
                </HBox>  
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavJadwal">
                    <FontIcon iconLiteral="fas-calendar-alt" styleClass="nav-icon"/>
                    <Label text="Kelola Jadwal" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavPromo">
                    <FontIcon iconLiteral="fas-percent" styleClass="nav-icon"/>
                    <Label text="Kelola Promo" styleClass="nav-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="nav-item" onMouseClicked="#handleNavLaporan">
                    <FontIcon iconLiteral="fas-chart-bar" styleClass="nav-icon"/>
                    <Label text="Laporan Penjualan" styleClass="nav-label"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="logout-item" onMouseClicked="#handleLogout">
                <FontIcon iconLiteral="fas-sign-out-alt" styleClass="logout-icon"/>
                <Label text="Logout" styleClass="logout-label"/>
            </HBox>

        </VBox>
    </left>

    <center>
        <StackPane>

            <VBox styleClass="content-area">

                <HBox alignment="CENTER_LEFT" styleClass="topbar">
                    <VBox>
                        <Label text="Kelola Kereta" styleClass="page-title"/>
                        <Label text="Manajemen data kereta CityRailGO" styleClass="page-subtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblAdminName" text="Halo, Admin" styleClass="admin-name"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="toolbar">
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-box">
                        <FontIcon iconLiteral="fas-search" styleClass="search-icon"/>
                        <TextField fx:id="tfSearch" promptText="Cari nama atau nomor kereta..." styleClass="search-field"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnTambah" styleClass="btn-primary" onAction="#handleTambahKereta">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <FontIcon iconLiteral="fas-plus" styleClass="btn-icon"/>
                                <Label text="Tambah Kereta" styleClass="btn-label"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>

                <VBox spacing="14" styleClass="table-card" VBox.vgrow="ALWAYS">
                    <Label text="Daftar Kereta" styleClass="card-title"/>
                    <TableView fx:id="tblKereta" styleClass="kereta-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNo" text="No" prefWidth="50"/>
                            <TableColumn fx:id="colNomorKereta" text="Nomor KA" prefWidth="130"/>
                            <TableColumn fx:id="colNama" text="Nama Kereta" prefWidth="210"/>
                            <TableColumn fx:id="colJumlahGerbong" text="Gerbong" prefWidth="90"/>
                            <TableColumn fx:id="colKapasitas" text="Kapasitas" prefWidth="100"/>
                            <TableColumn fx:id="colKelas" text="Kelas Didukung" prefWidth="260"/>
                            <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                            <TableColumn fx:id="colAksi" text="Aksi" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <StackPane fx:id="modalOverlay" styleClass="modal-backdrop" alignment="CENTER" visible="false" managed="false">
                <VBox styleClass="modal-card" maxWidth="520" maxHeight="650" spacing="16">
                    <padding>
                        <Insets top="26" right="28" bottom="26" left="28"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="lblModalTitle" text="Tambah Kereta" styleClass="modal-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <FontIcon iconLiteral="fas-times" styleClass="modal-close-icon" onMouseClicked="#handleTutupModal"/>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="Nomor KA" styleClass="form-label"/>
                        <TextField fx:id="tfNomorKereta" promptText="Contoh: KA 26" styleClass="form-field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Nama Kereta" styleClass="form-label"/>
                        <TextField fx:id="tfNama" promptText="Contoh: Mutiara Selatan" styleClass="form-field"/>
                    </VBox>

                    <HBox spacing="10">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Gerbong Eksekutif (50 kursi)" styleClass="form-label"/>
                            <TextField fx:id="tfGerbongEksekutif" promptText="0" styleClass="form-field"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Gerbong Bisnis (60 kursi)" styleClass="form-label"/>
                            <TextField fx:id="tfGerbongBisnis" promptText="0" styleClass="form-field"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Gerbong Ekonomi (80 kursi)" styleClass="form-label"/>
                            <TextField fx:id="tfGerbongEkonomi" promptText="0" styleClass="form-field"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="Kalkulasi Kapasitas &amp; Gerbong" styleClass="form-label"/>
                        <TextField fx:id="tfKalkulasi" styleClass="form-field" style="-fx-background-color:#E2E8F0; -fx-text-fill:#6E84A8;" editable="false" text="0 Kursi (Total Gerbong: 0)"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Kelas yang Didukung" styleClass="form-label"/>
                        <VBox spacing="8" styleClass="checkbox-box">
                            <HBox spacing="16">
                                <CheckBox fx:id="chkEksekutif" text="Eksekutif" styleClass="form-check"/>
                                <CheckBox fx:id="chkBisnis" text="Bisnis" styleClass="form-check"/>
                                <CheckBox fx:id="chkEkonomi" text="Ekonomi" styleClass="form-check"/>
                            </HBox>
                        </VBox>
                        <Label text="Kelas yang dicentang akan tersedia sebagai opsi saat membuat jadwal baru." styleClass="form-hint" wrapText="true"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Status" styleClass="form-label"/>
                        <ComboBox fx:id="cbStatus" promptText="Pilih status" styleClass="form-field" maxWidth="Infinity"/>
                    </VBox>

                    <Label fx:id="lblModalError" styleClass="modal-error" wrapText="true" visible="false" managed="false"/>

                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="Batal" styleClass="btn-secondary" onAction="#handleTutupModal"/>
                        <Button fx:id="btnSimpan" text="Simpan" styleClass="btn-primary" onAction="#handleSimpanKereta"/>
                    </HBox>
                </VBox>
            </StackPane>

        </StackPane>
    </center>

</BorderPane>
